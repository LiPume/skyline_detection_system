# Skyline — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is ignored by git (see .gitignore).

# ── Backend ────────────────────────────────────────────────────────────────
# Port where the FastAPI backend is running.
VITE_BACKEND_PORT=8000

# ── WebSocket ──────────────────────────────────────────────────────────────
# Full WebSocket URL. If omitted, falls back to:
#   ws://<window.location.hostname>:<VITE_BACKEND_PORT>/api/ws/video_stream
# VITE_WS_URL=ws://localhost:8000/api/ws/video_stream
